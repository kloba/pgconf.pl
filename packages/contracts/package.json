{
  "name": "@pgconf/contracts",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cfp": {
      "types": "./dist/cfp.d.ts",
      "default": "./dist/cfp.js"
    },
    "./contact": {
      "types": "./dist/contact.d.ts",
      "default": "./dist/contact.js"
    },
    "./newsletter": {
      "types": "./dist/newsletter.d.ts",
      "default": "./dist/newsletter.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
