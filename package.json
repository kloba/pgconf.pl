{
  "name": "pgconf-pl",
  "version": "0.0.0",
  "private": true,
  "description": "PGConf Poland 2026 — conference website",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "swa start",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start",
    "build": "pnpm --filter contracts build && pnpm --filter web build && pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "preview": "pnpm --filter web preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@azure/static-web-apps-cli": "^2.0.2"
  }
}
