{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["lib/**/*", "cfp-submit/**/*.ts", "contact/**/*.ts", "newsletter/**/*.ts", "ping/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
