---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import Countdown from '~/components/Countdown.astro';
import SponsorPlaceholder from '~/components/SponsorPlaceholder.astro';
import logo from '~/assets/logo.png';
import { CONFERENCE } from '~/lib/conference';

const news = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const sponsorSlots = Array.from({ length: 5 }, (_, i) => i + 1);

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});
---
<Base
  title={CONFERENCE.name}
  description={CONFERENCE.description}
>
  <!-- ============ HERO ============ -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__bg" aria-hidden="true">
      <div class="glow-gold"></div>
      <div class="geo-pattern"></div>
      <svg
        class="hero__svg"
        viewBox="0 0 1200 800"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="hero-rule" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"  stop-color="rgba(212,169,58,0)"/>
            <stop offset="50%" stop-color="rgba(212,169,58,0.6)"/>
            <stop offset="100%" stop-color="rgba(212,169,58,0)"/>
          </linearGradient>
          <pattern id="hero-chev" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M0 60 L40 20 L80 60" fill="none" stroke="rgba(212,169,58,0.10)" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="1200" height="800" fill="url(#hero-chev)" opacity="0.4"/>
        <path d="M-50 720 L1250 320" stroke="url(#hero-rule)" stroke-width="1" fill="none"/>
        <path d="M-50 760 L1250 360" stroke="url(#hero-rule)" stroke-width="1" fill="none" opacity="0.35"/>
        <g transform="translate(1080,80)" opacity="0.7">
          <circle cx="0" cy="0" r="2" fill="#d4a93a"/>
          <path d="M-30 0 L-6 0 M6 0 L30 0 M0 -30 L0 -6 M0 6 L0 30"
                stroke="rgba(212,169,58,0.45)" stroke-width="1"/>
        </g>
      </svg>
      <div class="vignette"></div>
    </div>

    <div class="container hero__inner">
      <div class="hero__content">
        <p class="pill anim-fade delay-1">Save the Date</p>

        <h1 id="hero-title" class="hero__title anim-rise delay-2">
          PGConf <span class="hero__title-accent">Poland</span> 2026
        </h1>

        <p class="hero__lede anim-rise delay-3">
          The PostgreSQL Europe community returns to the Baltic coast.
          One day, one historic venue, one shared craft.
        </p>

        <dl class="hero__meta anim-rise delay-4">
          <div>
            <dt>Date</dt>
            <dd><time datetime={CONFERENCE.date}>{CONFERENCE.dateLabel}</time></dd>
          </div>
          <div class="hero__meta-divider" aria-hidden="true"></div>
          <div>
            <dt>Location</dt>
            <dd>{CONFERENCE.venue.city}, {CONFERENCE.venue.country}</dd>
          </div>
        </dl>

        <div class="hero__ctas anim-rise delay-5">
          <a href="/attendance" class="btn btn--primary">Buy Tickets</a>
          <a href="/cfp" class="btn btn--outline">Call for Papers</a>
        </div>
      </div>

      <div class="hero__art anim-fade delay-3">
        <div class="hero__art-glow" aria-hidden="true"></div>
        <Image
          src={logo}
          alt={`${CONFERENCE.name} crest`}
          width={520}
          height={520}
          densities={[1, 2]}
          loading="eager"
          fetchpriority="high"
          class="hero__logo"
        />
      </div>
    </div>

    <a href="#registration" class="hero__scroll" aria-label="Scroll to next section">
      <span></span>
    </a>
  </section>

  <!-- ============ REGISTRATION CALLOUT ============ -->
  <section id="registration" class="section section--tight" aria-labelledby="reg-title">
    <div class="container">
      <div class="reg-strip edge-glow grain-soft">
        <div class="reg-strip__pulse" aria-hidden="true"></div>
        <p class="reg-strip__eyebrow">Registration</p>
        <p id="reg-title" class="reg-strip__msg">
          Register from <strong>{CONFERENCE.registrationOpensLabel}</strong>
          <span class="reg-strip__sep">—</span>
          <em>limited seats, single track, sixty guests</em>
        </p>
        <a href="/attendance" class="link-reveal reg-strip__cta">
          Notify me
          <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ COUNTDOWN — showcase moment ============ -->
  <section class="section countdown-section" aria-labelledby="countdown-title">
    <div class="container">
      <div class="countdown-section__head">
        <p class="eyebrow">The Long Wait</p>
        <h2 id="countdown-title" class="countdown-section__title">Counting down to Gdańsk</h2>
      </div>
      <div class="countdown-section__body">
        <Countdown />
      </div>
    </div>
  </section>

  <!-- ============ EVENT DETAILS ============ -->
  <section class="section" aria-labelledby="details-title">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">The Particulars</p>
        <h2 id="details-title">Event details</h2>
      </div>

      <div class="details-grid">
        <article class="card details-card grain-soft">
          <p class="details-card__label">Date &amp; Venue</p>
          <p class="details-card__date">
            <time datetime={CONFERENCE.date}>{CONFERENCE.dateLabel}</time>
          </p>
          <p class="details-card__venue">{CONFERENCE.venue.name}</p>
          <address class="details-card__addr">
            {CONFERENCE.venue.street}<br/>
            {CONFERENCE.venue.postalCode} {CONFERENCE.venue.city}<br/>
            {CONFERENCE.venue.country}
          </address>

          <dl class="details-card__facts">
            <div>
              <dt>Format</dt><dd>Single-day, single-track</dd>
            </div>
            <div>
              <dt>Capacity</dt><dd>60 guests</dd>
            </div>
            <div>
              <dt>Catering</dt><dd>Coffee breaks, buffet lunch, beverage package</dd>
            </div>
          </dl>

          <a href="/about" class="btn btn--outline details-card__cta">Find out more</a>
        </article>

        <aside class="details-rooms">
          <div class="details-map">
            <iframe
              src={`https://www.openstreetmap.org/export/embed.html?bbox=${CONFERENCE.venue.longitude - 0.006}%2C${CONFERENCE.venue.latitude - 0.003}%2C${CONFERENCE.venue.longitude + 0.006}%2C${CONFERENCE.venue.latitude + 0.003}&layer=mapnik&marker=${CONFERENCE.venue.latitude}%2C${CONFERENCE.venue.longitude}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map showing ${CONFERENCE.venue.name}`}
            ></iframe>
            <a
              class="details-map__link"
              href={`https://www.openstreetmap.org/?mlat=${CONFERENCE.venue.latitude}&mlon=${CONFERENCE.venue.longitude}#map=17/${CONFERENCE.venue.latitude}/${CONFERENCE.venue.longitude}`}
              target="_blank"
              rel="noopener"
            >Open in OpenStreetMap ↗</a>
          </div>

          <div>
            <p class="details-rooms__label">Rooms in use</p>
            <ul class="details-rooms__list">
              {CONFERENCE.rooms.map((r) => (
                <li>
                  <span class="details-rooms__bullet" aria-hidden="true"></span>
                  {r}
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============ LATEST NEWS ============ -->
  <section class="section" aria-labelledby="news-title">
    <div class="container">
      <div class="section-title section-title--row">
        <div>
          <p class="eyebrow">Despatches</p>
          <h2 id="news-title">Latest news</h2>
        </div>
        <a href="/news" class="link-reveal news-grid__more">All updates →</a>
      </div>

      {news.length === 0 ? (
        <div class="news-empty card grain-soft">
          <p class="news-empty__title">No despatches just yet.</p>
          <p class="news-empty__sub">
            Programme and registration announcements will land here in spring 2026.
          </p>
        </div>
      ) : (
        <div class="news-grid">
          {news.map((post) => (
            <article class="card news-card">
              <p class="news-card__date">
                <time datetime={post.data.date.toISOString()}>
                  {dateFmt.format(post.data.date)}
                </time>
              </p>
              <h3 class="news-card__title">
                <a href={`/news/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p class="news-card__excerpt">{post.data.excerpt}</p>
              <a href={`/news/${post.slug}`} class="link-reveal news-card__more">
                Read more
                <svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ============ SPONSORS STRIP ============ -->
  <section class="section sponsors-section" aria-labelledby="sponsors-title">
    <div class="container">
      <div class="section-title section-title--center">
        <p class="eyebrow">In Good Company</p>
        <h2 id="sponsors-title">Sponsor lineup announcing soon</h2>
      </div>

      <ul class="sponsors-grid">
        {sponsorSlots.map((seed) => (
          <li class="sponsor-slot">
            <SponsorPlaceholder seed={seed} label="Your name here" muted />
          </li>
        ))}
      </ul>

      <div class="sponsors-cta">
        <a href="/sponsors" class="btn btn--primary">Become a sponsor</a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* ============ HERO ============ */
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(6rem, 5rem + 6vw, 9rem);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.85;
  }

  .hero__inner {
    position: relative;
    z-index: var(--z-content);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  @media (min-width: 960px) {
    .hero__inner {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-20);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
    max-width: 640px;
  }
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 5vw, 6.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-fg-strong);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'wght' 380;
  }
  .hero__title-accent {
    color: var(--color-gold);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'wght' 420;
  }
  .hero__lede {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    line-height: 1.4;
    color: var(--color-fg-muted);
    max-width: 38ch;
    font-variation-settings: 'opsz' 36, 'SOFT' 30, 'wght' 350;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
    margin: var(--space-2) 0 0;
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    width: 100%;
  }
  .hero__meta div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hero__meta dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-gold);
  }
  .hero__meta dd {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--color-fg-strong);
    margin: 0;
  }
  .hero__meta-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .hero__art {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    max-width: 480px;
    margin-inline: auto;
    width: 100%;
  }
  .hero__art-glow {
    position: absolute;
    inset: -10%;
    background: radial-gradient(circle at 50% 50%, rgba(212,169,58,0.45) 0%, transparent 55%);
    filter: blur(30px);
    z-index: 0;
  }
  .hero__logo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    object-fit: contain;
    filter:
      drop-shadow(0 30px 60px rgba(0,0,0,0.55))
      drop-shadow(0 0 30px rgba(212,169,58,0.25));
    animation: hero-logo-float 8s var(--ease-in-out-soft) infinite;
  }
  @keyframes hero-logo-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: var(--space-6);
    transform: translateX(-50%);
    z-index: 2;
    width: 22px;
    height: 36px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 6px;
    transition: border-color var(--dur-base) var(--ease-out-quart);
  }
  .hero__scroll span {
    width: 2px;
    height: 6px;
    background: var(--color-gold);
    border-radius: var(--radius-pill);
    animation: scroll-bob 1.6s var(--ease-in-out-soft) infinite;
  }
  @keyframes scroll-bob {
    0%   { transform: translateY(0); opacity: 1; }
    70%  { transform: translateY(10px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* ============ REGISTRATION STRIP ============ */
  .reg-strip {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4) var(--space-6);
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .reg-strip__pulse {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--color-gold), var(--color-red));
    box-shadow: 0 0 16px rgba(212,169,58,0.6);
  }
  .reg-strip__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-gold);
    margin-left: var(--space-2);
  }
  .reg-strip__msg {
    flex: 1 1 auto;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--color-fg);
    font-variation-settings: 'opsz' 36, 'SOFT' 40;
  }
  .reg-strip__msg strong { color: var(--color-fg-strong); font-weight: 500; }
  .reg-strip__msg em { color: var(--color-fg-muted); font-style: italic; }
  .reg-strip__sep { color: var(--color-gold); padding: 0 var(--space-2); }

  /* ============ COUNTDOWN SECTION ============ */
  .countdown-section {
    position: relative;
  }
  .countdown-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(212,169,58,0.10) 0%, transparent 70%);
    pointer-events: none;
  }
  .countdown-section__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .countdown-section__title {
    font-size: var(--fs-3xl);
    font-variation-settings: 'opsz' 96, 'SOFT' 60, 'wght' 400;
    max-width: 24ch;
  }
  .countdown-section__body {
    display: flex;
    justify-content: center;
  }

  /* ============ EVENT DETAILS ============ */
  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: stretch;
  }
  @media (min-width: 880px) {
    .details-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-12);
    }
  }

  .details-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
  }
  .details-card__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-gold);
  }
  .details-card__date {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    color: var(--color-fg-strong);
    font-variation-settings: 'opsz' 96, 'SOFT' 50;
    line-height: 1.1;
  }
  .details-card__venue {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--color-gold-bright);
    margin-top: var(--space-2);
  }
  .details-card__addr {
    font-style: normal;
    line-height: 1.7;
    color: var(--color-fg-muted);
    font-size: var(--fs-sm);
  }
  .details-card__facts {
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-border-cool);
    padding-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .details-card__facts > div {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }
  .details-card__facts dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-fg-faint);
  }
  .details-card__facts dd {
    font-size: var(--fs-sm);
    color: var(--color-fg);
    margin: 0;
  }
  .details-card__cta { margin-top: var(--space-4); align-self: flex-start; }

  .details-rooms {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .details-map {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 11;
    background: var(--color-bg-elev);
  }
  .details-map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    filter: contrast(0.95) saturate(0.85);
  }
  .details-map__link {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(7, 14, 28, 0.85);
    backdrop-filter: blur(6px);
    border: 1px solid var(--color-border);
    color: var(--color-gold);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.4rem 0.65rem;
    border-radius: 4px;
    text-decoration: none;
    z-index: 2;
  }
  .details-map__link:hover { color: var(--color-gold-warm, var(--color-gold)); border-color: var(--color-gold); }
  .details-rooms__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-gold);
    margin-bottom: var(--space-3);
  }
  .details-rooms__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .details-rooms__list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-fg);
    padding: var(--space-2) 0;
    border-bottom: 1px dashed var(--color-border-cool);
  }
  .details-rooms__bullet {
    width: 6px; height: 6px;
    background: var(--color-gold);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  /* ============ NEWS ============ */
  .section-title--row {
    display: flex;
    flex-direction: row;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-6);
  }
  .section-title--row::after { display: none; }
  .section-title--row > div::after {
    content: '';
    display: block;
    width: 64px;
    height: 2px;
    margin-top: var(--space-4);
    background: linear-gradient(90deg, var(--color-gold) 0%, var(--color-gold-warm) 100%);
  }
  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 720px) {
    .news-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .news-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    min-height: 240px;
  }
  .news-card__date {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-gold);
  }
  .news-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    color: var(--color-fg-strong);
    line-height: 1.2;
    font-variation-settings: 'opsz' 36, 'SOFT' 40, 'wght' 450;
  }
  .news-card__title a { color: inherit; }
  .news-card__title a:hover { color: var(--color-gold-bright); }
  .news-card__excerpt {
    font-size: var(--fs-sm);
    color: var(--color-fg-muted);
    line-height: 1.6;
    flex: 1 1 auto;
  }
