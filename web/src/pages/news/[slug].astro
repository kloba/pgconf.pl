---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---
<Base title={`${post.data.title} — PGConf Poland 2026`} description={post.data.excerpt}>
  <article class="section section--hero article">
    <div class="container article__inner">
      <p class="eyebrow">
        <a href="/news">News</a> · <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
      </p>
      <h1 class="page-title">{post.data.title}</h1>
      <p class="lede">{post.data.excerpt}</p>
      <span class="rule rule--gold" aria-hidden="true"></span>
      <div class="prose">
        <Content />
      </div>
      <p class="back"><a href="/news" class="link-reveal">← Back to all news</a></p>
    </div>
  </article>
</Base>

<style>
  .article__inner { max-width: 70ch; margin-inline: auto; }
  .eyebrow a { color: inherit; text-decoration: none; }
  .eyebrow a:hover { color: var(--color-gold-warm, var(--color-gold)); }
  .prose {
    line-height: 1.7;
    color: var(--color-fg);
    margin-top: var(--space-8);
  }
  .prose :global(p) { margin: 0 0 var(--space-4); }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    margin: var(--space-8) 0 var(--space-3);
    color: var(--color-fg);
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: var(--space-6) 0 var(--space-2);
  }
  .prose :global(a) { color: var(--color-gold); }
  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 var(--space-4);
    padding-left: 1.4rem;
  }
  .prose :global(li) { margin-bottom: var(--space-2); }
  .prose :global(code) {
    font-family: var(--font-mono);
    background: var(--color-bg-elev);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.92em;
  }
  .back { margin-top: var(--space-12); }
</style>
