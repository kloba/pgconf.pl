---
/**
 * Countdown — interactive island.
 *
 * Renders a circular SVG progress arc + four cells (D / H / M / S) and a "Days To Go" label.
 * Server-renders the initial state from the build-time clock, then a small client script
 * updates every second. Respects prefers-reduced-motion (skips per-second SVG arc updates,
 * falls back to a coarser 60s tick and static arc).
 */
import { CONFERENCE } from '~/lib/conference';
import { diff, pad, progress } from '~/lib/countdown';

interface Props {
  label?: string;
  /** Anchor used to compute arc fraction (defaults to 'today'). */
  anchorISO?: string;
}
const { label = 'Days To Go', anchorISO } = Astro.props;
const target = new Date(CONFERENCE.startsAt);
const anchor = anchorISO ? new Date(anchorISO) : new Date();

const initial = diff(target);
const initialPct = progress(target, anchor);

// SVG arc geometry
const SIZE = 280;
const STROKE = 6;
const RADIUS = (SIZE - STROKE) / 2;
const CIRC = 2 * Math.PI * RADIUS;
// Arc spans 240deg (5/6 of circle) — opens at the bottom like the reference design.
const ARC_FRACTION = 240 / 360;
const arcLength = CIRC * ARC_FRACTION;
const dashOffset = arcLength * (1 - initialPct);
---
<div
  class="countdown"
  data-countdown
  data-target={target.toISOString()}
  data-anchor={anchor.toISOString()}
  data-arc-length={arcLength}
>
  <div class="countdown__arc">
    <svg viewBox={`0 0 ${SIZE} ${SIZE}`} aria-hidden="true">
      <defs>
        <linearGradient id="countdown-track" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%"  stop-color="rgba(245,236,214,0.10)" />
          <stop offset="100%" stop-color="rgba(245,236,214,0.04)" />
        </linearGradient>
        <linearGradient id="countdown-fill" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%"   stop-color="#f0c75a" />
          <stop offset="55%"  stop-color="#d4a93a" />
          <stop offset="100%" stop-color="#d8232a" />
        </linearGradient>
        <filter id="countdown-glow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>

      <g transform={`rotate(150 ${SIZE/2} ${SIZE/2})`}>
        <circle
          cx={SIZE/2} cy={SIZE/2} r={RADIUS}
          fill="none"
          stroke="url(#countdown-track)"
          stroke-width={STROKE}
          stroke-linecap="round"
          stroke-dasharray={`${arcLength} ${CIRC}`}
        />
        <circle
          data-countdown-arc
          cx={SIZE/2} cy={SIZE/2} r={RADIUS}
          fill="none"
          stroke="url(#countdown-fill)"
          stroke-width={STROKE}
          stroke-linecap="round"
          stroke-dasharray={`${arcLength} ${CIRC}`}
          stroke-dashoffset={dashOffset}
          filter="url(#countdown-glow)"
          style={`transition: stroke-dashoffset 700ms cubic-bezier(0.16, 1, 0.3, 1);`}
        />
      </g>

      <!-- terminal beads -->
      <g transform={`rotate(150 ${SIZE/2} ${SIZE/2})`}>
        <circle cx={SIZE/2 + RADIUS} cy={SIZE/2} r="3.5" fill="#d4a93a" opacity="0.85"/>
      </g>
    </svg>

    <div class="countdown__center">
      <div class="countdown__days" data-countdown-days>{initial.days}</div>
      <div class="countdown__label">{label}</div>
    </div>
  </div>

  <div class="countdown__cells" aria-live="polite" aria-atomic="true">
    <div class="countdown__cell">
      <span class="countdown__num" data-countdown-d>{pad(initial.days)}</span>
      <span class="countdown__cell-label">Days</span>
    </div>
    <span class="countdown__sep">·</span>
    <div class="countdown__cell">
      <span class="countdown__num" data-countdown-h>{pad(initial.hours)}</span>
      <span class="countdown__cell-label">Hours</span>
    </div>
    <span class="countdown__sep">·</span>
    <div class="countdown__cell">
      <span class="countdown__num" data-countdown-m>{pad(initial.minutes)}</span>
      <span class="countdown__cell-label">Min</span>
    </div>
    <span class="countdown__sep">·</span>
    <div class="countdown__cell">
      <span class="countdown__num" data-countdown-s>{pad(initial.seconds)}</span>
      <span class="countdown__cell-label">Sec</span>
    </div>
  </div>

  <p class="countdown__caption">
    Until <time datetime={CONFERENCE.startsAt}>{CONFERENCE.dateLabel}</time>, {CONFERENCE.venue.city}
  </p>
</div>

<style>
  .countdown {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }

  .countdown__arc {
    position: relative;
    width: min(280px, 80vw);
    aspect-ratio: 1;
    filter: drop-shadow(0 12px 36px rgba(212,169,58,0.2));
  }
  .countdown__arc svg {
    width: 100%;
    height: 100%;
  }
  .countdown__center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
  }
  .countdown__days {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 2.5rem + 4vw, 5.5rem);
    font-weight: 350;
    font-variation-settings: 'opsz' 144, 'SOFT' 80;
    color: var(--color-fg-strong);
    line-height: 1;
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
  }
  .countdown__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-gold);
  }

  .countdown__cells {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3);
    font-family: var(--font-mono);
  }
  .countdown__cell {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 44px;
  }
  .countdown__num {
    font-size: var(--fs-xl);
    color: var(--color-fg);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
  .countdown__cell-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-fg-faint);
  }
  .countdown__sep {
    color: var(--color-gold-warm);
    font-size: var(--fs-xl);
    line-height: 1;
    transform: translateY(-2px);
  }

  .countdown__caption {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--color-fg-muted);
  }
</style>

<script>
  function tickAll() {
    const nodes = document.querySelectorAll<HTMLElement>('[data-countdown]');
    if (!nodes.length) return;

    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

    nodes.forEach((root) => {
      const targetISO = root.dataset.target;
      const anchorISO = root.dataset.anchor;
      const arcLength = Number(root.dataset.arcLength ?? 0);
      if (!targetISO) return;
      const target = new Date(targetISO).getTime();
      const anchor = anchorISO ? new Date(anchorISO).getTime() : Date.now();

      const dDays = root.querySelector<HTMLElement>('[data-countdown-days]');
      const dD = root.querySelector<HTMLElement>('[data-countdown-d]');
      const dH = root.querySelector<HTMLElement>('[data-countdown-h]');
      const dM = root.querySelector<HTMLElement>('[data-countdown-m]');
      const dS = root.querySelector<HTMLElement>('[data-countdown-s]');
      const arc = root.querySelector<SVGCircleElement>('[data-countdown-arc]');

      const pad = (n: number) => n.toString().padStart(2, '0');

      const update = () => {
        const totalMs = target - Date.now();
        if (totalMs <= 0) {
          if (dDays) dDays.textContent = '0';
          if (dD) dD.textContent = '00';
          if (dH) dH.textContent = '00';
          if (dM) dM.textContent = '00';
          if (dS) dS.textContent = '00';
          if (arc) arc.style.strokeDashoffset = String(arcLength);
          return false;
        }
        const seconds = Math.floor((totalMs / 1000) % 60);
        const minutes = Math.floor((totalMs / 1000 / 60) % 60);
        const hours   = Math.floor((totalMs / 1000 / 60 / 60) % 24);
        const days    = Math.floor(totalMs / 1000 / 60 / 60 / 24);

        if (dDays) dDays.textContent = String(days);
        if (dD) dD.textContent = pad(days);
        if (dH) dH.textContent = pad(hours);
        if (dM) dM.textContent = pad(minutes);
        if (dS) dS.textContent = pad(seconds);

        if (arc && arcLength) {
          const total = target - anchor;
          const pct = total > 0 ? Math.max(0, Math.min(1, (target - Date.now()) / total)) : 0;
          arc.style.strokeDashoffset = String(arcLength * (1 - pct));
        }
        return true;
      };

      update();
      const interval = reduceMotion ? 60_000 : 1_000;
      const id = window.setInterval(() => {
        if (!update()) window.clearInterval(id);
      }, interval);
      // Clean up on view transition
      document.addEventListener('astro:before-swap', () => window.clearInterval(id), { once: true });
    });
  }
  tickAll();
  document.addEventListener('astro:after-swap', tickAll);
</script>
